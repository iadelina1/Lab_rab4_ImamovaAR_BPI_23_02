<Window x:Class="Lab_rab4_ImamovaAR_BPI_23_02.View.WindowEmployee"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Lab_rab4_ImamovaAR_BPI_23_02.ViewModel"
        Title="Сотрудники" Height="400" Width="600"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.DataContext>
        <vm:PersonViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListView Grid.Row="0" 
                  ItemsSource="{Binding ListPersonDPO}" 
                  SelectedItem="{Binding SelectedPersonDPO}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Фамилия" DisplayMemberBinding="{Binding LastName}" Width="150"/>
                    <GridViewColumn Header="Имя" DisplayMemberBinding="{Binding FirstName}" Width="150"/>
                    <GridViewColumn Header="Должность" DisplayMemberBinding="{Binding Role}" Width="150"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Добавить" Command="{Binding AddPerson}" Width="105" Margin="5"/>
            <Button Content="Редактировать" Command="{Binding EditPerson}" Width="105" Margin="5"/>
            <Button Content="Удалить" Command="{Binding DeletePerson}" Width="105" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>