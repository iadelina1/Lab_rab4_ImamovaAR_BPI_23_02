<Window x:Class="Lab_rab4_ImamovaAR_BPI_23_02.View.WindowRole"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Справочник должностей" Height="350" Width="450">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#F3F3F3">
            <Button Content="Добавить" Command="{Binding AddRoleCommand}" Width="80" Height="25" Margin="5"/>
            <Button Content="Изменить" Command="{Binding EditRoleCommand}" Width="80" Height="25" Margin="5"/>
            <Button Content="Удалить" Command="{Binding DeleteRoleCommand}" Width="80" Height="25" Margin="5"/>
        </StackPanel>

        <Grid>
            <ListView ItemsSource="{Binding ListRole}" SelectedItem="{Binding SelectedRole}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Код" DisplayMemberBinding="{Binding Id}" Width="50"/>
                        <GridViewColumn Header="Наименование" DisplayMemberBinding="{Binding NameRole}" Width="250"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </DockPanel>
</Window>