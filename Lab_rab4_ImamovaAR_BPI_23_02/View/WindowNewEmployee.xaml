<Window x:Class="Lab_rab4_ImamovaAR_BPI_23_02.View.WindowNewEmployee"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Данные сотрудника" Height="300" Width="350" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20">
        <TextBlock Text="Фамилия:"/>
        <TextBox x:Name="tbLastName" Margin="0,5,0,10"/>

        <TextBlock Text="Имя:"/>
        <TextBox x:Name="tbFirstName" Margin="0,5,0,10"/>

        <TextBlock Text="Дата рождения:"/>
        <DatePicker x:Name="dpBirthday" Margin="0,5,0,10"/>

        <UniformGrid Columns="2" Margin="0,10,0,0">
            <Button Content="Сохранить" Click="Save_Click" Margin="5"/>
            <Button Content="Отмена" IsCancel="True" Margin="5"/>
        </UniformGrid>
    </StackPanel>
</Window>