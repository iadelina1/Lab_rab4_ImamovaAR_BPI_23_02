<Window x:Class="Lab_rab5_ImamovaAR_BPI_23_02.View.WindowNewEmployee"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Данные сотрудника" Height="450" Width="350" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">
    <StackPanel Margin="20">
        <TextBlock Text="Код:" Foreground="{DynamicResource WindowTextBrush}"/>
        <TextBox Text="{Binding NewId}" IsReadOnly="True" Background="#F0F0F0" Margin="0,5,0,10"/>

        <TextBlock Text="Должность:" Foreground="{DynamicResource WindowTextBrush}"/>
        <ComboBox ItemsSource="{Binding ListRole}" 
                  SelectedItem="{Binding NewRole}" 
                  DisplayMemberPath="NameRole"
                  Margin="0,5,0,10" Height="25"/>

        <TextBlock Text="Фамилия:" Foreground="{DynamicResource WindowTextBrush}"/>
        <TextBox Text="{Binding NewLastName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10"/>

        <TextBlock Text="Имя:" Foreground="{DynamicResource WindowTextBrush}"/>
        <TextBox Text="{Binding NewFirstName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10"/>

        <TextBlock Text="Дата рождения:" Foreground="{DynamicResource WindowTextBrush}"/>
        <Grid>
            <TextBox x:Name="tbBirthday" 
             Text="{Binding NewBirthday, StringFormat=\{0:dd.MM.yyyy\}, UpdateSourceTrigger=PropertyChanged}" 
             Margin="0,5,0,10"
             IsVisibleChanged="tbBirthday_IsVisibleChanged">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <DatePicker x:Name="ClBirthday" 
                SelectedDate="{Binding NewBirthday, UpdateSourceTrigger=PropertyChanged}" 
                Visibility="Hidden" 
                Margin="0,5,0,10"/>
        </Grid>
        
        <UniformGrid Columns="2" Margin="0,10,0,0">
            <Button Content="Сохранить" Click="Save_Click" Margin="5"/>
            <Button Content="Отмена" IsCancel="True" Margin="5"/>
        </UniformGrid>
    </StackPanel>
</Window>