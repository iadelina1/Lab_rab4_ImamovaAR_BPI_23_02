<Window x:Class="Lab_rab4_ImamovaAR_BPI_23_02.View.WindowNewRole"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Должность" Height="200" Width="300" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">

    <StackPanel Margin="20">
        <TextBlock Text="Название должности:" 
                   Foreground="{DynamicResource WindowTextBrush}" 
                   Margin="0,0,0,5"/>

        <TextBox Text="{Binding NewRoleName, UpdateSourceTrigger=PropertyChanged}" 
                 Height="30"
                 VerticalContentAlignment="Center"/>

        <UniformGrid Columns="2" Margin="0,20,0,0">
            <Button Content="ОК" Click="Accept_Click" Margin="5"/>
            <Button Content="Отмена" IsCancel="True" Margin="5"/>
        </UniformGrid>
    </StackPanel>
</Window>