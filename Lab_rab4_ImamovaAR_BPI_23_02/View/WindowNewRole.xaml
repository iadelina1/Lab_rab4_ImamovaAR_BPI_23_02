<Window x:Class="Lab_rab4_ImamovaAR_BPI_23_02.View.WindowNewRole"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Должность" Height="180" Width="300" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20">
        <TextBlock Text="Название должности:" Margin="0,0,0,5"/>
        <TextBox x:Name="tbRoleName" Height="25"/>

        <UniformGrid Columns="2" Margin="0,20,0,0">
            <Button Content="ОК" Click="Accept_Click" Margin="5"/>
            <Button Content="Отмена" IsCancel="True" Margin="5"/>
        </UniformGrid>
    </StackPanel>
</Window>