<Window x:Class="Lab_rab4_ImamovaAR_BPI_23_02.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Lab_rab4_ImamovaAR_BPI_23_02.ViewModel"
        mc:Ignorable="d"
        Title="Управление сотрудниками" Height="300" Width="500">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" 
                Orientation="Horizontal" 
                Background="#F3F3F3" 
                >

            <Button Content="Сотрудники" 
                Command="{Binding OpenEmployeeWindowCommand}" 
                Width="120" Height="40" 
                Margin="5" 
                Background="#E1E1E1"/>

            <Button Content="Должности" 
                Command="{Binding OpenRoleWindowCommand}" 
                Width="120" Height="40" 
                Margin="5" 
                Background="#E1E1E1"/>
        </StackPanel>

        <Grid Background="White">
        </Grid>
    </DockPanel>
</Window>