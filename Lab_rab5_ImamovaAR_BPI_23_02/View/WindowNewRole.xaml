<Window x:Class="Lab_rab5_ImamovaAR_BPI_23_02.View.WindowNewRole"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Должность" Height="250" Width="300" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">

    <StackPanel Margin="10">
        <TextBlock Text="Код:" 
                   Foreground="{DynamicResource WindowTextBrush}" 
                   Margin="0,0,0,5"/>
        <TextBox Text="{Binding NewRoleId}" 
                 IsReadOnly="True" 
                 Background="#F0F0F0" 
                 Height="30" 
                 Margin="0,0,0,10"/>

        <TextBlock Text="Название должности:" 
                   Foreground="{DynamicResource WindowTextBrush}" 
                   Margin="0,0,0,5"/>

        <TextBox Text="{Binding NewRoleName, UpdateSourceTrigger=PropertyChanged}" 
                 Height="30"
                 VerticalContentAlignment="Center"/>

        <UniformGrid Columns="2" Margin="0,20,0,0">
            <Button Content="ОК" 
            IsDefault="True"
            Command="{Binding AcceptCommand}"
            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
            Width="100" Height="30" Margin="5"/>
            <Button Content="Отмена" IsCancel="True" Margin="5"/>
        </UniformGrid>
    </StackPanel>
</Window>