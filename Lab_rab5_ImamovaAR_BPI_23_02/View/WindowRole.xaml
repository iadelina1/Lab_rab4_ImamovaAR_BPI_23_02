<Window x:Class="Lab_rab5_ImamovaAR_BPI_23_02.View.WindowRole"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Lab_rab5_ImamovaAR_BPI_23_02.ViewModel"
        Title="Должности" Height="350" Width="450"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.DataContext>
        <vm:RoleViewModel/>
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListView Grid.Row="0" 
                  ItemsSource="{Binding ListRole}" 
                  SelectedItem="{Binding SelectedRole}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Код" DisplayMemberBinding="{Binding Id}" Width="50"/>
                    <GridViewColumn Header="Название должности" DisplayMemberBinding="{Binding NameRole}" Width="300"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Добавить" Command="{Binding AddRole}" Width="90" Margin="5"/>
            <Button Content="Изменить" Command="{Binding EditRole}" Width="90" Margin="5"/>
            <Button Content="Удалить" Command="{Binding DeleteRole}" Width="90" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>